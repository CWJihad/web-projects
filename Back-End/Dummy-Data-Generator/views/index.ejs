<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Dummy Data Generator</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        body {
            background: #1a1a1a;
            color: white;
            margin: 0px;
            padding: 0px;
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }
    </style>
  </head>
  <body>
    <h1>Dummy Data Generator!</h1>
    <div id="gen-btn">
        <button type="button" class="btn btn-primary">Generate</button>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>

    <script>
        // const genBtn = document.getElementById("gen-btn")
        const genBtn = document.querySelector("#gen-btn>button")
        genBtn.addEventListener("click", async () => {
            // console.log("Working");
            let fetchData = await fetch('/generate') // get request on /generate
            let parseData = await fetchData.json() // making usable for frontend
            console.log(parseData);
            
        })
    </script>
  </body>
</html>